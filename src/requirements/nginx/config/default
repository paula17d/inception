# Default server configuration
#
server {
	# server listening on port 443, https so we need ssl
	listen 443 ssl default_server;
	listen [::]:443 ssl default_server;

	# change localhost URL to personalized URL
	server_name pdrettas.42.fr;

	# where our wordpress would be 
	root /var/www/html;
	# the name of our wordpress main page
	index index.php index.html index.htm;

	# the address of where the key and certificate will be put  
	ssl_certificate /etc/nginx/ssl/cert.crt;
	ssl_certificate_key /etc/nginx/ssl/key.key; 
    ssl_protocols TLSv1.2 TLSv1.3;

	# pass PHP scripts to FastCGI server
	location ~ \.php$ {
		include snippets/fastcgi-php.conf;
	
	#	# With php-fpm (or other unix sockets):
	#	# fastcgi_pass unix:/run/php/php7.4-fpm.sock;
	#	# With php-cgi (or other tcp sockets):
		fastcgi_pass wordpress:9000;
		fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
	}

	location / {
		# First attempt to serve request as file, then
		# as directory, then fall back to displaying a 404.
		try_files $uri $uri/ =404;
	}
}
